{
  "$schema": "https://biomejs.dev/schemas/2.4.14/schema.json",

  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },

  "files": {
    "ignoreUnknown": false
  },

  "formatter": {
    "enabled": true,
    "indentStyle": "tab",
    "lineWidth": 100
  },

  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,

      "suspicious/noArrayIndexKey": "warn",

      "a11y/useButtonType": "error",
      "a11y/useFocusableInteractive": "error",
      "a11y/useAltText": "error",
      "a11y/useMediaCaption": "warn",

      "style/noSingleLetterIdentifiers": "off",
      "style/useLiteralKeys": "off",

      "complexity/useOptionalChain": "warn"
    }
  },

  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "jsxQuoteStyle": "double",
      "trailingComma": "all"
    }
  },

  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  }
}
